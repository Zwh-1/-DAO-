# ═══════════════════════════════════════════════════════════════════════════════
# TrustAID Platform - 环境变量配置模板
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# 部署者私钥（用于合约部署）
# 格式：不带 0x 前缀的 64 位十六进制字符串
# 示例：DEPLOYER_PRIVATE_KEY=abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890
# ═══════════════════════════════════════════════════════════════════════════════
DEPLOYER_PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# ═══════════════════════════════════════════════════════════════════════════════
# Infura API Key（用于连接以太坊网络）
# 获取地址：https://infura.io/register
# 支持网络：Sepolia, Mumbai, Polygon, Mainnet
# ═══════════════════════════════════════════════════════════════════════════════
INFURA_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# 自定义 RPC URL（可选，优先级高于 Infura）
# 如果留空，将使用 Infura 或公共 RPC
# ═══════════════════════════════════════════════════════════════════════════════

# Sepolia RPC
SEPOLIA_RPC_URL=

# Polygon Mumbai RPC
MUMBAI_RPC_URL=

# Polygon Mainnet RPC
POLYGON_RPC_URL=

# Arbitrum One RPC
ARBITRUM_RPC_URL=

# Binance Smart Chain RPC
BSC_RPC_URL=

# Ethereum Mainnet RPC
MAINNET_RPC_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# Geth 私有节点配置（可选）
# 默认值：http://127.0.0.1:8545
# ═══════════════════════════════════════════════════════════════════════════════
GETH_URL=http://127.0.0.1:8545

# ═══════════════════════════════════════════════════════════════════════════════
# 区块浏览器 API Key（用于合约验证）
# 获取地址：
# - Etherscan: https://etherscan.io/myapikey
# - PolygonScan: https://polygonscan.com/myapikey
# - Arbiscan: https://arbiscan.io/myapikey
# - BscScan: https://bscscan.com/myapikey
# ═══════════════════════════════════════════════════════════════════════════════

# Ethereum Etherscan
ETHERSCAN_API_KEY=

# Polygon PolygonScan
POLYGONSCAN_API_KEY=

# Arbitrum Arbiscan
ARBITRUM_API_KEY=

# BSC BscScan
BSCSCAN_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# 申领金额配置（可选）
# 用于 ClaimVaultZK 合约部署参数
# 单位：Wei（1 ETH = 10^18 Wei）
# ═══════════════════════════════════════════════════════════════════════════════

# 最小申领金额（默认：1000 Wei）
MIN_CLAIM=1000

# 最大申领金额（默认：200000 Wei = 0.0002 ETH）
MAX_CLAIM=200000

# ClaimVaultZK 链上绑定（scripts/deploy.mjs；须与 anti_sybil_verifier 证明及白名单一致）
# 十进制或 0x 大整数；不配时 deploy 使用 0 / 0 / 1
# CLAIM_VAULT_MERKLE_ROOT=
# CLAIM_VAULT_PARAMETER_HASH=
# CLAIM_VAULT_PROJECT_ID=1

# 默认部署 snarkjs 导出的真实 Groth16Verifier（须已 circuits zk:export + contracts yarn compile）
# 无电路产物、仅本地占位调试时设为 1（主网/L2 禁止 Mock，除非 FORCE_MOCK_VERIFIER=1）
# USE_MOCK_ZK_VERIFIERS=1

# ═══════════════════════════════════════════════════════════════════════════════
# 其他配置（可选）
# ═══════════════════════════════════════════════════════════════════════════════

# 启用 Gas 报告（1=启用，0=禁用）
REPORT_GAS=0

# 后端 ABI 导出目录（默认：../backend/src/abis/）
BACKEND_ABI_DIR=../backend/src/abis/
