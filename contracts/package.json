    "export-abis": "node scripts/export-abis.js",
    "export-abi": "node scripts/export-abis.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.24.3"
  },
