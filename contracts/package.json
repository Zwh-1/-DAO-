{
  "name": "trustaid-contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "compile-and-export": "node scripts/compile-and-export-abis.js",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.mjs",
    "deploy:local": "hardhat run scripts/deploy.mjs --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.mjs --network sepolia",
