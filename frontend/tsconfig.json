{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*":            ["./src/*"],
      "@/components/*": ["src/components/*"],
      "@/hooks/*":      ["src/hooks/*"],
      "@/lib/*":        ["src/lib/*"],
      "@/store/*":      ["src/store/*"],
      "@/utils/*":      ["src/utils/*"],
      "@/types/*":      ["src/types/*"],
      "@/workers/*":    ["src/workers/*"],
      "@/app/*":        ["src/app/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "tests"]
}
