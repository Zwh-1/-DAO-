# 合约地址配置（开发环境）
# 注意：这些地址仅用于本地开发测试

# 后端 HTTP 地址（Next rewrites /v1 → 此处 origin；lib/api/client.ts baseURL 同变量）
NEXT_PUBLIC_BACKEND_URL=http://localhost:3010

# 默认网络（31337 = Hardhat 本地链）
NEXT_PUBLIC_DEFAULT_CHAIN_ID=31337

# Hardhat 节点 JSON-RPC 地址（不要使用后端 API URL）
NEXT_PUBLIC_RPC_URL=http://localhost:8545

# ClaimVault 合约地址
NEXT_PUBLIC_CLAIM_VAULT_ADDRESS=

# ClaimVaultZK 合约地址
NEXT_PUBLIC_CLAIM_VAULT_ZK_ADDRESS=

# IdentityRegistry 合约地址
NEXT_PUBLIC_IDENTITY_REGISTRY_ADDRESS=

# SBT 合约地址
NEXT_PUBLIC_SBT_ADDRESS=

# AnonymousClaim 合约地址
NEXT_PUBLIC_ANONYMOUS_CLAIM_ADDRESS=

# OracleManager 合约地址
NEXT_PUBLIC_ORACLE_MANAGER_ADDRESS=

# Governance 合约地址
NEXT_PUBLIC_GOVERNANCE_ADDRESS=

# FamilyMemberSBT 合约地址
NEXT_PUBLIC_FAMILY_MEMBER_SBT_ADDRESS=

# 电路文件路径（可选，默认使用 public/circuits）
# NEXT_PUBLIC_CIRCUITS_PATH=/circuits

# 是否启用电路预加载（默认：true）
# NEXT_PUBLIC_PRELOAD_CIRCUITS=true

# 证明过期时间（毫秒，默认：600000 = 10 分钟）
# NEXT_PUBLIC_PROOF_TTL=600000
