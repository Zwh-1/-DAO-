# 后端 API 地址（不含 /v1，代码内自动拼接）
NEXT_PUBLIC_BACKEND_URL=http://localhost:3010

# WalletConnect Project ID（可选，留空则仅支持 MetaMask injected）
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# 电路产物路径（相对于 /public，ZK Worker 读取）
# 需先按 circuits/README.md 生成 .wasm 和 .zkey 并放入 /public/circuits/build/
NEXT_PUBLIC_ZK_WASM_PATH=/circuits/build/anti_sybil_verifier.wasm
NEXT_PUBLIC_ZK_ZKEY_PATH=/circuits/build/anti_sybil_verifier_final.zkey
