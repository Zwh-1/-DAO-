# 后端 API 根 URL（与 frontend/lib/api/client.ts 中 API_CONFIG.baseURL 一致；不含 /v1；默认与 backend 端口 3010 一致）
NEXT_PUBLIC_API_BASE_URL=http://localhost:3010
# 若历史配置仍使用下列变量名，请迁移为 NEXT_PUBLIC_API_BASE_URL
# NEXT_PUBLIC_BACKEND_URL=http://localhost:3010

# WalletConnect Project ID（可选，留空则仅支持 MetaMask injected）
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# 电路产物路径（相对于 /public，ZK Worker 读取）
# 需先按 circuits/README.md 生成 .wasm 和 .zkey 并放入 /public/circuits/build/
NEXT_PUBLIC_ZK_WASM_PATH=/circuits/build/anti_sybil_verifier.wasm
NEXT_PUBLIC_ZK_ZKEY_PATH=/circuits/build/anti_sybil_verifier_final.zkey

# anonymous_claim 主路径（默认与下方 public/circuits/build/ 文件名一致）
NEXT_PUBLIC_ANONYMOUS_CLAIM_WASM_PATH=/circuits/build/anonymous_claim.wasm
NEXT_PUBLIC_ANONYMOUS_CLAIM_ZKEY_PATH=/circuits/build/anonymous_claim_final.zkey

# 申领页标题与说明（可选，见 frontend/config/claimCampaign.ts）
# NEXT_PUBLIC_CLAIM_CAMPAIGN_TITLE=社区匿名空投
# NEXT_PUBLIC_CLAIM_CAMPAIGN_DESC=完成本地零知识证明后即可领取，密钥不离端。

# 非本地链时配置 RPC（与 frontend/lib/contracts/addresses.ts 中 Sepolia / 主网一致）
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
# NEXT_PUBLIC_MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
