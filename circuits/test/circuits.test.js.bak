import fs from "node:fs";
import os from "node:os";
import path from "node:path";
import { fileURLToPath } from "node:url";
import { wasm as wasm_tester } from "circom_tester";

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const root = path.join(__dirname, "..");

// circom_tester 默认调用 PATH 中的 `circom`；本地用 circom2 代理
const localBin = path.join(root, "bin");
process.env.PATH = `${localBin}${path.delimiter}${process.env.PATH}`;
process.env.CIRCOM = path.join(localBin, "circom.cmd");  // 显式指定 circom 路径

/**
 * 复制项目树到临时目录
 * 修复说明�? * 1. 复制所�?src 电路文件
 * 2. 复制 circomlib 依赖（处�?include 语句�? * 3. 复制 package.json（用于依赖解析）
 * 4. 使用正斜杠路径（circom 兼容�? * 
 * @returns {string} 临时目录路径（正斜杠�? */
function copyTreeToAsciiTmp() {
  const tmp = fs.mkdtempSync(path.join(os.tmpdir(), "trustaid-cir-"));
  
  // 创建 node_modules 目录
  fs.mkdirSync(path.join(tmp, "node_modules"), { recursive: true });
  
  // 复制 src 目录（所有电路文件）
  fs.cpSync(path.join(root, "src"), path.join(tmp, "src"), { recursive: true });
  
  // 复制 circomlib（必须）- 处理 include 依赖
  const circomlibSrc = path.join(root, "node_modules", "circomlib");
  const circomlibDst = path.join(tmp, "node_modules", "circomlib");
  if (fs.existsSync(circomlibSrc)) {
    fs.cpSync(circomlibSrc, circomlibDst, { recursive: true });
  }
  
  // 复制 package.json（用于依赖解析）
  if (fs.existsSync(path.join(root, "package.json"))) {
    fs.cpSync(path.join(root, "package.json"), path.join(tmp, "package.json"));
  }
  
  // 调试：验证文件是否已复制
  const testFile = path.join(tmp, "src", "anti_sybil_claim.circom");
  if (!fs.existsSync(testFile)) {
    console.error("�?文件复制失败！临时目�?", tmp);
    console.error("�?测试文件不存�?", testFile);
    const srcDir = path.join(tmp, "src");
    if (fs.existsSync(srcDir)) {
      const files = fs.readdirSync(srcDir);
      console.error("�?src 目录内容:", files);
    } else {
      console.error("�?src 目录不存�?", srcDir);
    }
  }
  
  // 返回正斜杠路�?  return tmp.replace(/\\/g, '/');
}

/**
 * 构建电路路径（使用正斜杠，circom 兼容�? * @param {string} tmpDir - 临时目录
 * @param {string} circuitName - 电路文件名（不含扩展名）
 * @returns {string} 正斜杠路�? */
function circuitPath(tmpDir, circuitName) {
  return `${tmpDir}/src/${circuitName}.circom`;
}

// Windows 部分环境�?circom2 原生进程可能不稳定；CI/Linux 或设�?RUN_CIRCOM_TESTS=1 时启用�?const runHeavy = process.env.RUN_CIRCOM_TESTS === "1";

// 修复说明：Windows �?circom2 无法处理临时目录路径，直接使用项目根目录
const useProjectRoot = true;  // Windows 修复：使用项目根目录而非临时目录

(runHeavy ? describe : describe.skip)("TrustAid circuits (phase 5)", function () {
  this.timeout(120000);

  let testRoot;
  before(function () {
    // Windows 修复：直接使用项目根目录
    testRoot = useProjectRoot ? root : copyTreeToAsciiTmp();
  });

  after(function () {
    // Windows 修复：不删除项目根目�?    if (!useProjectRoot) {
      try {
        if (testRoot) fs.rmSync(testRoot, { recursive: true, force: true });
      } catch {
        // ignore
      }
    }
  });

  it("identity_commitment: constraints pass", async function () {
    const circuit = await wasm_tester(path.join(testRoot, "src/identity_commitment.circom"));
    const witness = await circuit.calculateWitness({
      social_id_hash: "100",
      secret: "200",
      trapdoor: "300"
    });
    await circuit.checkConstraints(witness);
  });

  it("anti_sybil_verifier: compiles (完整 witness 需链下构�?Merkle)", async function () {
    await wasm_tester(path.join(testRoot, "src/anti_sybil_verifier.circom"));
  });
});

// ══════════════════════════════════════════════════════════════════════════════�?// 边界值测试套件（阶段 1：测试覆盖率提升�?80%�?// ══════════════════════════════════════════════════════════════════════════════�?
