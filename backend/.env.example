# =============================================================================
# TrustAID 后端环境变量（与 src/config.js 及 src/config/*.js 对齐）
# 复制为 .env 或 .env.local（.env.local 由 config.js 加载，且不覆盖已有进程环境变量）
# =============================================================================

# --- 服务 ---
PORT=3010
NODE_ENV=development
# 允许的 CORS 来源（逗号分隔），留空则允许全部
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# 日志级别：DEBUG | INFO | WARN | ERROR（见 src/utils/logger.js）
# LOG_LEVEL=INFO
# 将 ERROR/WARN 与 audit 追加到文件
# LOG_FILE=./logs/trustaid-backend.log

# --- JWT / 管理 / 认证安全（src/config.js）---
JWT_SECRET=change-me-in-production
# 未设置 JWT_SECRET 时，代码内建开发默认值为 dev-change-me-trustaid（生产校验会拒绝该值）
ADMIN_TOKEN=
BYPASS_AUTH=0
ALLOW_BYPASS_BODY_AUTH=0
ALLOW_INSECURE_ADMIN=0
ALLOW_SERVER_NULLIFIER_DERIVE=0

# --- 链 RPC 与链 ID ---
RPC_URL=http://127.0.0.1:8545
# EIP-712、支付通道状态签名等（须与节点 chainId 一致；Hardhat 默认 31337）
CHAIN_ID=887766

# --- 合约地址（0x + 40 位十六进制；示例与一次 localhost 真实 ZK 部署一致，见 contracts/deployments/latest-localhost.json）---
CLAIM_VAULT_ADDRESS=0x34e076673e34fb5637538Ff81FA5789546bCb98b
IDENTITY_REGISTRY_ADDRESS=0x2Af24c4A03cb5d87406F5B036A6d14E9B51d6F90
SBT_ADDRESS=0xF4d585B8d9fC0CEdA2afD5d85dc2700e0d1657CB
ANONYMOUS_CLAIM_ADDRESS=0x2E4BED9834Cd2646744C73A59B3CA54455c4EEE6
GOVERNANCE_ADDRESS=0xc9DD5f021d0F701Ac7f27690878023D1E0a8e025
# 链上角色：memory | chain | chain_with_memory_fallback（生产若用 chain 须配 RPC + PLATFORM_ROLE_REGISTRY_ADDRESS）
ROLES_SOURCE=memory
PLATFORM_ROLE_REGISTRY_ADDRESS=0x2EaAa8d3AFCA54a70162AFf31D5a60B5A1188874
ARBITRATOR_POOL_ADDRESS=0xEb2893a1674805DA9A5B79D7b286357A10ee40AA

# 中继私钥：须 64 位十六进制（无 0x）；与 RPC + CLAIM_VAULT_ADDRESS 同时配置时启用 ClaimVault 链上中继
RELAYER_PRIVATE_KEY=cea7f4244240320b85051f8ec0e49b7240b0a89acc709d89d485ced0c2c85210

# --- MySQL（src/db/pool.js、src/config/database.js）---
# 留空：Nullifier / claim 等可走内存兜底
DATABASE_URL=mysql://root:123456@127.0.0.1:3306/trustaid_dev
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000

# --- 业务 ---
MIN_CHALLENGE_STAKE=100
# 支付通道：生产或显式开启时强制校验调用方为 channel participant
# FORCE_CHANNEL_PARTICIPANT_CHECK=0

# --- AI 客服与审计（src/config/ai.js、aiAudit.service.js 的 AI_AUDIT_MODEL）---
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
