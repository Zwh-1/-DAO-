# 依赖文件
node_modules/
package-lock.json

# 环境变量文件（高敏感，严禁提交）
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# ZKP 电路密钥文件（最高敏感度，严禁提交）
# 包含：.zkey（证明密钥）、vkey.json（验证密钥）、.wasm（电路编译产物）
src/zkp/circuits/keys/*.zkey
src/zkp/circuits/keys/*_vkey.json
src/zkp/circuits/keys/*.wasm
src/zkp/circuits/keys/proving_key/
src/zkp/circuits/keys/verification_key/

# ZKP 证明文件（高敏感度，包含用户隐私数据）
# 包含：proof_*.json（零知识证明）、public_inputs_*.json（公开输入）
src/zkp/circuits/proofs/
src/zkp/circuits/publicInputs/

# ZKP 电路调试产物（可选提交，但建议排除）
src/zkp/circuits/*.sym
src/zkp/circuits/*.json
src/zkp/circuits/*.circom.witness

# 日志文件（防止磁盘溢出）
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 测试覆盖率报告
coverage/
*.lcov
.nyc_output/

# 临时文件与备份
*.tmp
*.bak
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.db

# IDE 配置文件
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace

# 构建产物（生产环境）
dist/
build/

# Docker 数据卷（本地开发）
docker-data/
.volumes/

# 数据库 SQLite 文件（如使用）
*.sqlite
*.sqlite3

# 身份验证相关（高敏感）
*.pem
*.key
*.crt
*.p12
*.pfx

# 钱包私钥文件（绝对禁止提交）
*.json
!package.json
!package-lock.json
wallet/
keystore/

# 多签钱包配置
multisig-config/

# AI 模型缓存（可选）
models-cache/
.onnx/
.pytorch/

# 性能分析文件
*.prof
*.profile
heapdump/

# 临时上传文件
uploads/
temp/
